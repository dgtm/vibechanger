{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File (.venv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: video_ai main (.venv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jobs/video_ai/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
